@using AHM.Audit.Data
@inject AuditDbContext DbContext

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AHM Audit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .sidebar { min-height: 100vh; background: #1e293b; padding: 0; width: 220px; }
        .sidebar-header { padding: 20px; border-bottom: 1px solid #334155; }
        .sidebar-header h5 { color: #fff; margin: 0; font-weight: 700; }
        .sidebar-header small { color: #94a3b8; }
        .nav-link { color: #cbd5e1; padding: 10px 20px; border-radius: 0; }
        .nav-link:hover { background: #334155; color: #fff; }
        .nav-section { color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; padding: 12px 20px 4px; }
        .main-content { padding: 30px; min-height: 100vh; }
        .card { border: none; border-radius: 12px; }
        .card-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; border-radius: 12px 12px 0 0 !important; }
    </style>
</head>
<body>
<div class="d-flex">
    @{
        var sessionUser = Context.Session.GetString("User");
        var isAdmin = sessionUser != null && DbContext.Users.Any(u => u.Username == sessionUser && u.IsAdmin);
        var hasArchive = DbContext.AuditoriaArchives.Any();
    }

    <div class="sidebar flex-shrink-0">
        <div class="sidebar-header">
            <h5><i class="bi bi-clipboard2-check me-2"></i>AHM Audit</h5>
            <small>@sessionUser</small>
        </div>
        <nav class="nav flex-column mt-2">
            <span class="nav-section">Principal</span>
            @if (isAdmin)
            {
                <a class="nav-link" href="/"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            }
            <a class="nav-link" href="/Auditorias"><i class="bi bi-clipboard-check me-2"></i>Auditorias</a>
            <a class="nav-link" href="/Auditorias/Create"><i class="bi bi-plus-circle me-2"></i>Nova Auditoria</a>

            @if (hasArchive)
            {
                <a class="nav-link" href="/Auditorias/Archive"><i class="bi bi-archive me-2"></i>Arquivo</a>
            }

            @if (isAdmin)
            {
                <span class="nav-section">Administração</span>
                <a class="nav-link" href="/Admin/Users"><i class="bi bi-people me-2"></i>Utilizadores</a>
                <a class="nav-link" href="/Admin/Persons"><i class="bi bi-person-badge me-2"></i>Agentes/Officers</a>
            }

            <span class="nav-section">Conta</span>
            <a class="nav-link text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-left me-2"></i>Sair</a>
        </nav>
    </div>

    <div class="main-content flex-grow-1">
        @RenderBody()
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
