@using AHM.Audit.Data
@inject AuditDbContext DbContext

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AHM Audit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; }
        .sidebar { min-height: 100vh; background: #1e293b; padding: 0; width: 220px; }
        .sidebar-header { padding: 20px; border-bottom: 1px solid #334155; }
        .sidebar-header h5 { color: #fff; margin: 0; font-weight: 700; }
        .sidebar-header small { color: #94a3b8; }
        .nav-link { color: #cbd5e1; padding: 10px 20px; border-radius: 0; }
        .nav-link:hover { background: #334155; color: #fff; }
        .nav-link.active { background: #0078d4; color: #fff; }
        .nav-section { color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; padding: 12px 20px 4px; }
        .main-content { padding: 30px; min-height: 100vh; }
        .card { border: none; border-radius: 12px; }
        .card-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; border-radius: 12px 12px 0 0 !important; }
    </style>
</head>
<body>
<div class="d-flex">
    @{
        var sessionUser = Context.Session.GetString("User");
        var currentUserObj = sessionUser != null ? DbContext.Users.FirstOrDefault(u => u.Username == sessionUser) : null;
        var isAdmin = currentUserObj?.IsAdmin ?? false;
        var canViewDashboard = isAdmin || (currentUserObj?.CanViewDashboard ?? false);
        var currentPath = Context.Request.Path.Value ?? "";
    }

    <div class="sidebar flex-shrink-0">
        <div class="sidebar-header">
            <h5><i class="bi bi-clipboard2-check me-2"></i>AHM Audit</h5>
            <small>@sessionUser</small>
        </div>
        <nav class="nav flex-column mt-2">
            <span class="nav-section">Principal</span>
            @if (canViewDashboard)
            {
                <a class="nav-link @(currentPath == "/" ? "active" : "")" href="/"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            }
            <a class="nav-link @(currentPath.StartsWith("/Auditorias") && !currentPath.Contains("Create") && !currentPath.Contains("Archive") ? "active" : "")" href="/Auditorias">
                <i class="bi bi-clipboard-check me-2"></i>Auditorias
            </a>
            <a class="nav-link @(currentPath.Contains("Create") ? "active" : "")" href="/Auditorias/Create">
                <i class="bi bi-plus-circle me-2"></i>Nova Auditoria
            </a>
            <a class="nav-link @(currentPath.Contains("Archive") ? "active" : "")" href="/Auditorias/Archive">
                <i class="bi bi-archive me-2"></i>Arquivo
            </a>

            @if (isAdmin)
            {
                <span class="nav-section">Administração</span>
                <a class="nav-link @(currentPath.Contains("/Admin/Users") ? "active" : "")" href="/Admin/Users">
                    <i class="bi bi-people me-2"></i>Utilizadores
                </a>
                <a class="nav-link @(currentPath.Contains("/Admin/Persons") ? "active" : "")" href="/Admin/Persons">
                    <i class="bi bi-person-badge me-2"></i>Agentes/Officers
                </a>
                <a class="nav-link @(currentPath.Contains("/Admin/Settings") ? "active" : "")" href="/Admin/Settings">
                    <i class="bi bi-gear me-2"></i>Configurações
                </a>
                <a class="nav-link @(currentPath.Contains("/Admin/Backup") ? "active" : "")" href="/Admin/Backup">
                    <i class="bi bi-database me-2"></i>Backup & Restauro
                </a>
            }

            <span class="nav-section">Conta</span>
            <a class="nav-link text-danger" href="/Account/Logout">
                <i class="bi bi-box-arrow-left me-2"></i>Sair
            </a>
        </nav>
    </div>

    <div class="main-content flex-grow-1">
        @RenderBody()
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
