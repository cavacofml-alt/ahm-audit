@page
@model AHM.Audit.Pages.Auditorias.EditModel
@{
    ViewData["Title"] = "Editar Auditoria";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        <i class="bi bi-pencil-square me-2"></i>Editar Auditoria
        @if (Model.Auditoria?.IsFinalized == true)
        {
            <span class="badge bg-success ms-2"><i class="bi bi-lock-fill me-1"></i>Finalizada</span>
        }
        else
        {
            <span class="badge bg-secondary ms-2"><i class="bi bi-pencil me-1"></i>Rascunho</span>
        }
    </h2>
    <a href="/Auditorias" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
</div>

@if (Model.Auditoria?.IsFinalized == true && !Model.IsAdmin)
{
    <div class="alert alert-success">
        <i class="bi bi-lock-fill me-2"></i><strong>Auditoria finalizada</strong> — não pode ser editada. Contacta um administrador para reabrir.
    </div>
}
@if (Model.IsAdmin && Model.Auditoria?.IsFinalized == true)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between">
        <span><i class="bi bi-lock-fill me-2"></i><strong>Auditoria finalizada.</strong> Como administrador podes reabrir.</span>
        <form method="post" asp-page-handler="Unfinalize" asp-route-id="@Model.Auditoria.Id" class="d-inline">
            <button type="submit" class="btn btn-sm btn-warning"><i class="bi bi-unlock me-1"></i>Reabrir</button>
        </form>
    </div>
}

<!-- Modal para razão do NO -->
<div class="modal fade" id="noReasonModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-x-circle me-2"></i>Motivo da não conformidade</h5>
            </div>
            <div class="modal-body">
                <p id="noReasonItemLabel" class="fw-bold"></p>
                <label class="form-label">Seleciona o motivo:</label>
                <select class="form-select" id="noReasonSelect">
                    <option value="">-- Seleciona --</option>
                    @foreach (var r in Model.NonConformityReasons)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="noReasonCancel">Cancelar</button>
                <button type="button" class="btn btn-danger" id="noReasonConfirm" disabled>Confirmar</button>
            </div>
        </div>
    </div>
</div>

<span class="badge bg-secondary" id="autosaveStatus" style="font-size:11px;display:none">
    <i class="bi bi-cloud-check me-1"></i>Guardado
</span>

<form method="post">
    <input type="hidden" asp-for="Auditoria.Id" />
    <input type="hidden" asp-for="Auditoria.CreatedAt" />

    <!-- Informação Geral -->
    <div class="card mb-4">
        <div class="card-header fw-bold"><i class="bi bi-info-circle me-2"></i>Informação Geral</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Audit Agent</label>
                    <select class="form-select" asp-for="Auditoria.Agent">
                        <option value="">-- Selecionar --</option>
                        @foreach (var a in Model.Agents)
                        {
                            if (Model.Auditoria.Agent == a)
                            {
                                <option value="@a" selected>@a</option>
                            }
                            else
                            {
                                <option value="@a">@a</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">AHM Officer</label>
                    <select class="form-select" asp-for="Auditoria.AhmOfficer">
                        <option value="">-- Selecionar --</option>
                        @foreach (var o in Model.Officers)
                        {
                            if (Model.Auditoria.AhmOfficer == o)
                            {
                                <option value="@o" selected>@o</option>
                            }
                            else
                            {
                                <option value="@o">@o</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ticket Number</label>
                    <input class="form-control" asp-for="Auditoria.Ticket" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date</label>
                    <input class="form-control" type="date" asp-for="Auditoria.Date" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Airline</label>
                    <input class="form-control" asp-for="Auditoria.Airline" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Aircraft Type</label>
                    <input class="form-control" asp-for="Auditoria.Aircraft" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Registration</label>
                    <input class="form-control" asp-for="Auditoria.Registration" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Revision Updates</label>
                    <input class="form-control" asp-for="Auditoria.RevisionUpdates" />
                </div>
            </div>
        </div>
    </div>

    <!-- Checklist -->
    <div class="card mb-4">
        <div class="card-header fw-bold"><i class="bi bi-check2-square me-2"></i>Checklist W&B</div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:50%">Item</th>
                        <th class="text-center">YES</th>
                        <th class="text-center">NO</th>
                        <th class="text-center">N/A</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var items = new[]
                        {
                            ("B1 - Standard units and codes",       "B1",             Model.Auditoria.B1),
                            ("B2 - Crew and crew baggage weights",  "B2",             Model.Auditoria.B2),
                            ("B3 - Passenger and baggage weights",  "B3",             Model.Auditoria.B3),
                            ("C1 - Aircraft Type or fleet",         "C1",             Model.Auditoria.C1),
                            ("C2 - Balance/Special info",           "C2",             Model.Auditoria.C2),
                            ("C2.3 - Sup info",                     "C2_3",           Model.Auditoria.C2_3),
                            ("C3 - Basic index/MAR RC Formula",     "C3",             Model.Auditoria.C3),
                            ("C4.1 - Take-off",                     "C4_TakeOff",     Model.Auditoria.C4_TakeOff),
                            ("C4.1 - Zero-Fuel",                    "C4_ZeroFuel",    Model.Auditoria.C4_ZeroFuel),
                            ("C4.1 - Landing",                      "C4_Landing",     Model.Auditoria.C4_Landing),
                            ("C4.1 - Inflight",                     "C4_Inflight",    Model.Auditoria.C4_Inflight),
                            ("C4.1 - Ideal Trim",                   "C4_IdealTrim",   Model.Auditoria.C4_IdealTrim),
                            ("C5 - Fuel",                           "C5",             Model.Auditoria.C5),
                            ("C7.1 - Stab trim",                    "C7_1",           Model.Auditoria.C7_1),
                            ("D1 - Dimensions and limits",          "D1",             Model.Auditoria.D1),
                            ("D2 - Holds",                          "D2",             Model.Auditoria.D2),
                            ("D3 - ULD",                            "D3",             Model.Auditoria.D3),
                            ("D5.1 - Cabin",                        "D5_1",           Model.Auditoria.D5_1),
                            ("D5.2 - Cabin Crew Seats",             "D5_2",           Model.Auditoria.D5_2),
                            ("D6.2 - Seatmap",                      "D6_2",           Model.Auditoria.D6_2),
                            ("E1 - DOW/DOI (BW/BI)",                "E1_DOW",         Model.Auditoria.E1_DOW),
                            ("E1 - MRW",                            "E1_MRW",         Model.Auditoria.E1_MRW),
                            ("E1 - MTOW",                           "E1_MTOW",        Model.Auditoria.E1_MTOW),
                            ("E1 - MZFW",                           "E1_MZFW",        Model.Auditoria.E1_MZFW),
                            ("E1 - MLAW",                           "E1_MLAW",        Model.Auditoria.E1_MLAW),
                            ("E2.1 - Crew Codes",                   "E2_1",           Model.Auditoria.E2_1),
                            ("E2.2 - Crew Distribution",            "E2_2",           Model.Auditoria.E2_2),
                            ("E3.1 - Pantry Distribution",          "E3_1",           Model.Auditoria.E3_1),
                            ("G1 - ULD Compatibility",              "G1",             Model.Auditoria.G1),
                            ("Revision update was correct?",        "RevisionUpdate", Model.Auditoria.RevisionUpdate),
                            ("LIR",                                 "LIR",            Model.Auditoria.LIR),
                            ("LS",                                  "LS",             Model.Auditoria.LS),
                            ("Database Printout",                   "DatabasePrintout", Model.Auditoria.DatabasePrintout),
                        };
                    }
                    @{
                        var noReasons = string.IsNullOrEmpty(Model.Auditoria.NoReasons)
                            ? new Dictionary<string, string>()
                            : Model.Auditoria.NoReasons.Split(';', StringSplitOptions.RemoveEmptyEntries)
                                .Select(p => p.Split('=', 2))
                                .Where(p => p.Length == 2)
                                .ToDictionary(p => p[0], p => p[1]);
                    }
                    @foreach (var (label, field, value) in items)
                    {
                        var currentReason = noReasons.TryGetValue(field, out var r) ? r : null;
                        <tr id="row-@field">
                            <td>
                                @label
                                @if (value == "NO")
                                {
                                    <div class="small text-danger" id="reason-@field">
                                        <i class="bi bi-exclamation-circle me-1"></i>@(currentReason ?? "sem razão registada")
                                    </div>
                                }
                            </td>
                            <td class="text-center"><input type="radio" name="check-@field" value="YES" class="form-check-input checklist-radio" data-field="@field" data-label="@label" @(value == "YES" ? "checked" : "") @(Model.IsLocked ? "disabled" : "") /></td>
                            <td class="text-center"><input type="radio" name="check-@field" value="NO"  class="form-check-input checklist-radio" data-field="@field" data-label="@label" @(value == "NO"  ? "checked" : "") @(Model.IsLocked ? "disabled" : "") /></td>
                            <td class="text-center"><input type="radio" name="check-@field" value="N/A" class="form-check-input checklist-radio" data-field="@field" data-label="@label" @(value == "N/A" ? "checked" : "") @(Model.IsLocked ? "disabled" : "") /></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Correções -->
    <div class="card mb-4">
        <div class="card-header fw-bold"><i class="bi bi-tools me-2"></i>Correções</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Correction Ticket</label>
                    <input class="form-control" asp-for="Auditoria.CorrectionTicket" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Reason for Re-certification</label>
                    <input class="form-control" asp-for="Auditoria.ReasonForRecertification" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Corrections Made</label>
                    <div class="d-flex gap-4 mt-1">
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.CorrectionsMade" value="YES" @(Model.Auditoria.CorrectionsMade == "YES" ? "checked" : "") /><label class="form-check-label">YES</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.CorrectionsMade" value="NO"  @(Model.Auditoria.CorrectionsMade == "NO"  ? "checked" : "") /><label class="form-check-label">NO</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.CorrectionsMade" value="N/A" @(Model.Auditoria.CorrectionsMade == "N/A" ? "checked" : "") /><label class="form-check-label">N/A</label></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Aircraft Re-certified</label>
                    <div class="d-flex gap-4 mt-1">
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.AircraftRecertified" value="YES" @(Model.Auditoria.AircraftRecertified == "YES" ? "checked" : "") /><label class="form-check-label">YES</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.AircraftRecertified" value="NO"  @(Model.Auditoria.AircraftRecertified == "NO"  ? "checked" : "") /><label class="form-check-label">NO</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="Auditoria.AircraftRecertified" value="N/A" @(Model.Auditoria.AircraftRecertified == "N/A" ? "checked" : "") /><label class="form-check-label">N/A</label></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Notas -->
    <div class="card mb-4">
        <div class="card-header fw-bold"><i class="bi bi-chat-left-text me-2"></i>Notas</div>
        <div class="card-body">
            <textarea class="form-control" asp-for="Auditoria.Notes" rows="4"></textarea>
        </div>
    </div>

    <div class="d-flex gap-2 mb-5">
        <button type="submit" name="action" value="save" class="btn btn-success btn-lg" @(Model.IsLocked ? "disabled" : "")>
            <i class="bi bi-save me-2"></i>Guardar
        </button>
        @if (!Model.IsLocked && Model.Auditoria?.IsFinalized != true)
        {
            <button type="submit" name="action" value="finalize" class="btn btn-primary btn-lg" onclick="return confirm('Finalizar auditoria? Ficará bloqueada para edição.')">
                <i class="bi bi-lock me-2"></i>Guardar e Finalizar
            </button>
        }
        <a href="/Auditorias" class="btn btn-outline-secondary btn-lg">Cancelar</a>
    </div>
</form>

<script>
const AUDIT_ID = @Model.Auditoria.Id;
let currentNoField = null, currentNoLabel = null, currentNoRadio = null;

function showAutosaveStatus() {
    const el = document.getElementById('autosaveStatus');
    el.style.display = 'inline-block';
    el.classList.remove('bg-danger');
    el.classList.add('bg-secondary');
    el.innerHTML = '<i class="bi bi-cloud-check me-1"></i>Guardado';
}
function showAutosaveError() {
    const el = document.getElementById('autosaveStatus');
    el.style.display = 'inline-block';
    el.classList.remove('bg-secondary');
    el.classList.add('bg-danger');
    el.innerHTML = '<i class="bi bi-exclamation-triangle me-1"></i>Erro ao guardar';
}

async function autosaveChecklist(field, value, reason) {
    const fd = new FormData();
    fd.append('id', AUDIT_ID);
    fd.append('field', field);
    fd.append('value', value);
    if (reason) fd.append('reason', reason);

    try {
        const resp = await fetch('/api/autosave', { method: 'POST', body: fd });
        if (!resp.ok) { showAutosaveError(); return; }
        showAutosaveStatus();
        const reasonEl = document.getElementById('reason-' + field);
        if (value === 'NO') {
            const text = '<i class="bi bi-exclamation-circle me-1"></i>' + (reason || 'sem razão registada');
            if (reasonEl) { reasonEl.innerHTML = text; }
            else {
                const row = document.getElementById('row-' + field);
                const cell = row.querySelector('td');
                const div = document.createElement('div');
                div.className = 'small text-danger';
                div.id = 'reason-' + field;
                div.innerHTML = text;
                cell.appendChild(div);
            }
        } else if (reasonEl) {
            reasonEl.remove();
        }
    } catch (e) { showAutosaveError(); }
}

// Checklist radios
document.querySelectorAll('.checklist-radio').forEach(radio => {
    radio.addEventListener('change', function() {
        const field = this.dataset.field;
        const label = this.dataset.label;
        if (this.value === 'NO') {
            currentNoField = field;
            currentNoLabel = label;
            currentNoRadio = this;
            this.dataset.confirmed = "false";
            document.getElementById('noReasonItemLabel').textContent = label;
            document.getElementById('noReasonSelect').value = '';
            document.getElementById('noReasonConfirm').disabled = true;
            new bootstrap.Modal(document.getElementById('noReasonModal')).show();
        } else {
            autosaveChecklist(field, this.value, null);
        }
    });
});

document.getElementById('noReasonSelect').addEventListener('change', function() {
    document.getElementById('noReasonConfirm').disabled = !this.value;
});

document.getElementById('noReasonConfirm').addEventListener('click', function() {
    const reason = document.getElementById('noReasonSelect').value;
    if (currentNoRadio) currentNoRadio.dataset.confirmed = "true";
    autosaveChecklist(currentNoField, 'NO', reason);
    bootstrap.Modal.getInstance(document.getElementById('noReasonModal')).hide();
});

document.getElementById('noReasonCancel').addEventListener('click', function() {
    if (currentNoRadio) currentNoRadio.checked = false;
    bootstrap.Modal.getInstance(document.getElementById('noReasonModal')).hide();
});

document.getElementById('noReasonModal').addEventListener('hidden.bs.modal', function() {
    if (currentNoRadio && currentNoRadio.checked && !currentNoRadio.dataset.confirmed) {
        currentNoRadio.checked = false;
    }
});
</script>
