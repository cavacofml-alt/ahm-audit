@page
@model AHM.Audit.Pages.Auditorias.IndexModel
@{
    ViewData["Title"] = "Auditorias";
    bool pt = true; // app is PT
}

@if (!string.IsNullOrEmpty(Model.FilterAirline) || !string.IsNullOrEmpty(Model.FilterNcField) || !string.IsNullOrEmpty(Model.FilterOfficer) || !string.IsNullOrEmpty(Model.FilterNcReason) || !string.IsNullOrEmpty(Model.FilterCompliance))
{
    <div class="alert alert-info d-flex align-items-center justify-content-between mb-3">
        <span>
            <i class="bi bi-funnel-fill me-2"></i>
            <strong>Filtro ativo:</strong>
            @if (!string.IsNullOrEmpty(Model.FilterAirline))  { <span class="badge bg-primary me-2">Airline: @Model.FilterAirline</span> }
            @if (!string.IsNullOrEmpty(Model.FilterNcField))  { <span class="badge bg-danger me-2">NOT OK: @Model.FilterNcField</span> }
            @if (!string.IsNullOrEmpty(Model.FilterOfficer))  { <span class="badge bg-secondary me-2">Officer: @Model.FilterOfficer</span> }
            @if (!string.IsNullOrEmpty(Model.FilterNcReason)) { <span class="badge bg-danger me-2">Razão: @Model.FilterNcReason</span> }
            @if (Model.FilterCompliance == "ok")    { <span class="badge bg-success me-2">Sem NOT OK</span> }
            @if (Model.FilterCompliance == "notok") { <span class="badge bg-danger me-2">Com NOT OK</span> }
        </span>
        <a href="/Auditorias" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x me-1"></i>Limpar filtro</a>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>@(pt ? "Auditorias" : "Audits")</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success" href="/Auditorias/Export"><i class="bi bi-file-earmark-excel me-1"></i>@(pt ? "Exportar CSV" : "Export CSV")</a>
        <a class="btn btn-primary" href="/Auditorias/Create"><i class="bi bi-plus-circle me-1"></i>@(pt ? "Nova Auditoria" : "New Audit")</a>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">Ticket</label>
                <input type="text" id="fTicket" class="form-control form-control-sm" placeholder="@(pt ? "Filtrar..." : "Filter...")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Agent</label>
                <input type="text" id="fAgent" class="form-control form-control-sm" placeholder="@(pt ? "Filtrar..." : "Filter...")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Airline</label>
                <input type="text" id="fAirline" class="form-control form-control-sm" placeholder="@(pt ? "Filtrar..." : "Filter...")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Aircraft</label>
                <input type="text" id="fAircraft" class="form-control form-control-sm" placeholder="@(pt ? "Filtrar..." : "Filter...")" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Registration</label>
                <input type="text" id="fReg" class="form-control form-control-sm" placeholder="@(pt ? "Filtrar..." : "Filter...")" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">@(pt ? "De" : "From")</label>
                <input type="date" id="fDateFrom" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">@(pt ? "Até" : "To")</label>
                <input type="date" id="fDateTo" class="form-control form-control-sm" />
            </div>
        </div>
        <div class="mt-2">
            <button class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
                <i class="bi bi-x-circle me-1"></i>@(pt ? "Limpar Filtros" : "Clear Filters")
            </button>
        </div>
    </div>
</div>

@if (!Model.Auditorias.Any())
{
    <div class="alert alert-info">@(pt ? "Ainda não existem auditorias registadas." : "No audits registered yet.")</div>
}
else
{
    <div id="selectionBar" class="alert alert-warning py-2 d-none d-flex align-items-center justify-content-between mb-2">
        <span><i class="bi bi-check2-square me-2"></i><strong id="selCount">0</strong> @(pt ? "auditoria(s) selecionada(s)" : "audit(s) selected")</span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" onclick="clearSelection()">@(pt ? "Limpar seleção" : "Clear selection")</button>
            @if (Model.IsAdmin)
            {
                <button class="btn btn-sm btn-danger" onclick="deleteSelected()">
                    <i class="bi bi-trash me-1"></i>@(pt ? "Apagar selecionadas" : "Delete selected")
                </button>
            }
        </div>
    </div>

    <form method="post" asp-page-handler="DeleteSelected" id="deleteForm">
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0" id="auditTable">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th style="width:40px">
                                <input type="checkbox" class="form-check-input" id="selectAll" onchange="toggleAll(this)" />
                            </th>
                            <th class="sortable" data-col="1">Ticket <i class="bi bi-arrow-down-up"></i></th>
                            <th class="sortable" data-col="2">Agent <i class="bi bi-arrow-down-up"></i></th>
                            <th class="sortable" data-col="3">Airline <i class="bi bi-arrow-down-up"></i></th>
                            <th class="sortable" data-col="4">Aircraft <i class="bi bi-arrow-down-up"></i></th>
                            <th class="sortable" data-col="5">Registration <i class="bi bi-arrow-down-up"></i></th>
                            <th class="sortable" data-col="6">Date <i class="bi bi-arrow-down-up"></i></th>
                            <th class="text-center sortable" data-col="7">YES <i class="bi bi-arrow-down-up"></i></th>
                            <th class="text-center sortable" data-col="8">NO <i class="bi bi-arrow-down-up"></i></th>
                            <th class="text-center sortable" data-col="9">N/A <i class="bi bi-arrow-down-up"></i></th>
                            <th>Prazo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @foreach (var item in Model.Auditorias)
                        {
                            var nos = Model.CountNo(item);
                            var rowClass = nos > 0 ? "table-danger" : "table-success";
                            <tr class="@rowClass" data-date="@item.Date.ToString("yyyy-MM-dd")">
                                <td><input type="checkbox" class="form-check-input row-check" name="selectedIds" value="@item.Id" onchange="updateSelection()" /></td>
                                <td><strong>@(string.IsNullOrEmpty(item.Ticket) ? "" : item.Ticket)</strong> @if (item.IsDraft && !item.IsFinalized) { <span class="badge bg-secondary">Rascunho</span> }</td>
                                <td>@item.Agent</td>
                                <td>@item.Airline</td>
                                <td>@item.Aircraft</td>
                                <td>@item.Registration</td>
                                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                <td class="text-center"><span class="badge bg-success">@Model.CountYes(item)</span></td>
                                <td class="text-center"><span class="badge bg-danger">@nos</span></td>
                                <td class="text-center"><span class="badge bg-secondary">@Model.CountNA(item)</span></td>
                                <td class="text-nowrap">
                                    @{
                                        var daysLeft = Model.DaysUntilDeadline(item);
                                    }
                                    @if (item.IsFinalized)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Finalizada</span>
                                    }
                                    else if (daysLeft < 0)
                                    {
                                        <span class="badge bg-danger" title="@(pt ? "Prazo de 2 semanas ultrapassado" : "2-week deadline passed")">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>Prazo expirado há @(-daysLeft)d
                                        </span>
                                    }
                                    else if (daysLeft <= 3)
                                    {
                                        <span class="badge bg-warning text-dark" title="@(pt ? "Prazo de 2 semanas a terminar" : "2-week deadline ending soon")">
                                            <i class="bi bi-clock-fill me-1"></i>Faltam @(daysLeft)d
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border" title="@(pt ? "Prazo para finalizar: 2 semanas" : "Deadline to finalize: 2 weeks")">
                                            Faltam @(daysLeft)d
                                        </span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    <a class="btn btn-sm btn-info text-white me-1" href="/Auditorias/Detail?id=@item.Id" title="@(pt ? "Ver detalhe" : "View detail")"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-sm btn-warning me-1" href="@(item.IsDraft && !item.IsFinalized ? $"/Auditorias/Create?draftId={item.Id}" : $"/Auditorias/Edit?id={item.Id}")" title="@(pt ? (item.IsDraft && !item.IsFinalized ? "Continuar rascunho" : "Editar") : (item.IsDraft && !item.IsFinalized ? "Resume draft" : "Edit"))"><i class="bi bi-pencil"></i></a>
                                    @if (Model.IsAdmin)
                                    {
                                        <button type="button" class="btn btn-sm btn-danger" onclick="deleteSingle(@item.Id)"><i class="bi bi-trash"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <input type="hidden" name="ids" id="hiddenIds" />
    </form>
}

<style>
.sortable { cursor: pointer; user-select: none; }
.sortable:hover { background: #374151; }
</style>

<script>
const pt = document.documentElement.lang === "pt" || true; // app is PT
const confirmMsg = pt ? 'Tens a certeza que queres apagar' : 'Are you sure you want to delete';
const auditWord  = pt ? 'auditoria(s)?' : 'audit(s)?';

let sortDir = {};
document.querySelectorAll('.sortable').forEach(th => {
    th.addEventListener('click', () => {
        const col = parseInt(th.dataset.col);
        sortDir[col] = !sortDir[col];
        const tbody = document.getElementById('tableBody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => {
            const aVal = a.cells[col]?.innerText.trim() || '';
            const bVal = b.cells[col]?.innerText.trim() || '';
            const n1 = parseFloat(aVal), n2 = parseFloat(bVal);
            if (!isNaN(n1) && !isNaN(n2)) return sortDir[col] ? n1 - n2 : n2 - n1;
            return sortDir[col] ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
        });
        rows.forEach(r => tbody.appendChild(r));
    });
});

function applyFilters() {
    const fTicket  = document.getElementById('fTicket').value.toLowerCase();
    const fAgent   = document.getElementById('fAgent').value.toLowerCase();
    const fAirline = document.getElementById('fAirline').value.toLowerCase();
    const fAcraft  = document.getElementById('fAircraft').value.toLowerCase();
    const fReg     = document.getElementById('fReg').value.toLowerCase();
    const fFrom    = document.getElementById('fDateFrom').value;
    const fTo      = document.getElementById('fDateTo').value;
    document.querySelectorAll('#tableBody tr').forEach(row => {
        const cells = row.cells;
        const rowDate = row.dataset.date;
        const textMatch =
            (!fTicket  || cells[1]?.innerText.toLowerCase().includes(fTicket)) &&
            (!fAgent   || cells[2]?.innerText.toLowerCase().includes(fAgent)) &&
            (!fAirline || cells[3]?.innerText.toLowerCase().includes(fAirline)) &&
            (!fAcraft  || cells[4]?.innerText.toLowerCase().includes(fAcraft)) &&
            (!fReg     || cells[5]?.innerText.toLowerCase().includes(fReg));
        const dateMatch = (!fFrom || rowDate >= fFrom) && (!fTo || rowDate <= fTo);
        row.style.display = (textMatch && dateMatch) ? '' : 'none';
    });
}

function clearFilters() {
    ['fTicket','fAgent','fAirline','fAircraft','fReg','fDateFrom','fDateTo'].forEach(id => document.getElementById(id).value = '');
    applyFilters();
}

['fTicket','fAgent','fAirline','fAircraft','fReg','fDateFrom','fDateTo'].forEach(id =>
    document.getElementById(id)?.addEventListener('input', applyFilters));

function updateSelection() {
    const checked = document.querySelectorAll('.row-check:checked');
    const bar = document.getElementById('selectionBar');
    document.getElementById('selCount').textContent = checked.length;
    bar.classList.toggle('d-none', checked.length === 0);
    bar.classList.toggle('d-flex', checked.length > 0);
}

function toggleAll(cb) {
    document.querySelectorAll('.row-check').forEach(c => {
        if (c.closest('tr').style.display !== 'none') c.checked = cb.checked;
    });
    updateSelection();
}

function clearSelection() {
    document.querySelectorAll('.row-check').forEach(c => c.checked = false);
    document.getElementById('selectAll').checked = false;
    updateSelection();
}

function deleteSelected() {
    const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(c => c.value);
    if (!ids.length) return;
    if (!confirm(`${confirmMsg} ${ids.length} ${auditWord}`)) return;
    document.getElementById('hiddenIds').value = ids.join(',');
    document.getElementById('deleteForm').submit();
}

function deleteSingle(id) {
    if (!confirm(`${confirmMsg} 1 ${auditWord}`)) return;
    document.getElementById('hiddenIds').value = id;
    document.getElementById('deleteForm').submit();
}
</script>
