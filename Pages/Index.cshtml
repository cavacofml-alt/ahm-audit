@page
@model AHM.Audit.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var pctInt = int.Parse(Model.PctYes);
    var scoreColor = pctInt >= 95 ? "#22c55e" : pctInt >= 85 ? "#f59e0b" : "#ef4444";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
</div>

<!-- Filters -->
<form method="get" class="card mb-4 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small fw-bold">De</label>
            <input type="date" name="from" class="form-control form-control-sm" value="@(Model.FilterFrom?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Até</label>
            <input type="date" name="to" class="form-control form-control-sm" value="@(Model.FilterTo?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Airline</label>
            <select name="airline" class="form-select form-select-sm">
                <option value="">Todas</option>
                @foreach (var a in Model.AllAirlines)
                { <option value="@a" selected="@(Model.FilterAirline == a)">@a</option> }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Agente</label>
            <select name="agent" class="form-select form-select-sm">
                <option value="">Todos</option>
                @foreach (var a in Model.AllAgents)
                { <option value="@a" selected="@(Model.FilterAgent == a)">@a</option> }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">Filtrar</button>
        </div>
        <div class="col-md-2">
            <a href="/" class="btn btn-outline-secondary btn-sm w-100">Limpar</a>
        </div>
    </div>
</form>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    @{
        var tmDiffTotal = Model.ThisMonthTotal - Model.LastMonthTotal;
        var tmDiffPct   = Model.ThisMonthPct - Model.LastMonthPct;
        var tmDiffNC    = Model.ThisMonthNC - Model.LastMonthNC;
    }
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Auditorias este mês</div>
                        <div class="kpi-value">@Model.ThisMonthTotal</div>
                        <div class="kpi-trend @(tmDiffTotal >= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffTotal >= 0 ? "up" : "down")"></i>
                            @(Math.Abs(tmDiffTotal)) vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-primary-soft"><i class="bi bi-clipboard-check text-primary"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Conformidade este mês</div>
                        <div class="kpi-value">@Model.ThisMonthPct<span style="font-size:1rem">%</span></div>
                        <div class="kpi-trend @(tmDiffPct >= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffPct >= 0 ? "up" : "down")"></i>
                            @(Math.Abs(tmDiffPct))% vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-success-soft"><i class="bi bi-check-circle text-success"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Não conformidades</div>
                        <div class="kpi-value">@Model.ThisMonthNC</div>
                        <div class="kpi-trend @(tmDiffNC <= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffNC <= 0 ? "down" : "up")"></i>
                            @(Math.Abs(tmDiffNC)) vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-danger-soft"><i class="bi bi-exclamation-triangle text-danger"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100" style="border-left: 4px solid @scoreColor">
            <div class="card-body text-center">
                <div class="kpi-label">Overall Quality Score</div>
                <div style="font-size:3rem;font-weight:900;color:@scoreColor;line-height:1">@Model.PctYes%</div>
                <div style="font-size:1.5rem;font-weight:700;color:@scoreColor">@Model.ScoreGrade</div>
                <div class="kpi-trend">Última: @Model.LastAuditTime</div>
            </div>
        </div>
    </div>
</div>

<!-- Dashboard grid: cada card é um widget independente, arrastável (admin) -->
<div id="dashboardGrid">

    @if (Model.CanViewTrend)
    {
    <div class="widget w-col-8" data-widget="trend">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-graph-up me-2"></i>Tendência 12 meses<span data-bs-toggle="tooltip" data-bs-placement="top" title="Evolução mensal da conformidade nos últimos 12 meses." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="trendChart" height="120"></canvas></div>
        </div>
    </div>
    }
    @if (Model.CanViewGlobalConformity)
    {
    <div class="widget w-col-4" data-widget="globalconformity">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-pie-chart me-2"></i>Conformidade global<span data-bs-toggle="tooltip" data-bs-placement="top" title="Rácio global entre itens OK e NOT OK. N/A não é contabilizado." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="resultChart" width="200" height="200"></canvas>
                <div class="mt-2 text-center">
                    <a href="/Auditorias?compliance=ok" class="badge bg-success me-2 text-decoration-none">OK @Model.TotalYes</a>
                    <a href="/Auditorias?compliance=notok" class="badge bg-danger text-decoration-none">NOT OK @Model.TotalNo</a>
                </div>
            </div>
        </div>
    </div>
    }

    @if (Model.CanViewHeatmap)
    {
    <div class="widget w-col-5" data-widget="heatmap">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-grid-3x3 me-2"></i>Checklist — detalhe por campo<span data-bs-toggle="tooltip" data-bs-placement="top" title="Mostra o resultado de cada item da checklist. Verde=OK, Vermelho=NOT OK, Cinza=N/A." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body p-0" style="max-height:500px;overflow-y:auto">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th style="width:45%">Campo</th>
                            <th class="text-center text-success">YES</th>
                            <th class="text-center text-danger">NO</th>
                            <th class="text-center text-secondary">N/A</th>
                            <th class="text-end">Conf.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.SectionData.OrderBy(x => x.key))
                        {
                            <tr class="table-secondary">
                                <td colspan="5"><strong>@s.name</strong></td>
                            </tr>
                            @foreach (var item in Model.ChecklistDetail.Where(x => x.SectionKey == s.key))
                            {
                                var conf = (item.Yes + item.No) > 0 ? item.Yes * 100 / (item.Yes + item.No) : -1;
                                var rowBg = conf == -1 ? "" : conf >= 95 ? "rgba(34,197,94,0.08)" : conf >= 80 ? "rgba(245,158,11,0.12)" : "rgba(239,68,68,0.08)";
                                var confColor = conf == -1 ? "text-muted" : conf >= 95 ? "text-success" : conf >= 80 ? "text-warning" : "text-danger";
                                <tr style="background:@rowBg">
                                    <td><small>@item.Label</small></td>
                                    <td class="text-center text-success fw-bold">@item.Yes</td>
                                    <td class="text-center text-danger fw-bold">
                                        @if (item.No > 0)
                                        {
                                            <a href="/Auditorias?ncFilter=@Uri.EscapeDataString(item.Label)" class="text-danger fw-bold text-decoration-none" title="Ver auditorias com NOT OK neste campo">@item.No</a>
                                        }
                                        else
                                        {
                                            <span>0</span>
                                        }
                                    </td>
                                    <td class="text-center text-secondary">@item.Na</td>
                                    <td class="text-end fw-bold @confColor">@(conf >= 0 ? conf + "%" : "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    }

    @if (Model.CanViewNonConformities)
    {
    <div class="widget w-col-7" data-widget="reasons">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-bar-chart-horizontal me-2"></i>Razões de NOT OK <small class="text-muted fw-normal">(clique para ver auditorias)</small><span data-bs-toggle="tooltip" data-bs-placement="top" title="Razões pré-definidas selecionadas quando um item foi marcado como NOT OK." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="reasonChart" height="200"></canvas></div>
        </div>
    </div>
    }

    @if (Model.CanViewSectionChart)
    {
    <div class="widget w-col-12" data-widget="section">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-bar-chart-steps me-2"></i>Resultados por secção (%)<span data-bs-toggle="tooltip" data-bs-placement="top" title="Conformidade agregada por secção da checklist (B, C, D, E, G)." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="sectionChart" height="80"></canvas></div>
        </div>
    </div>
    }

    @if (Model.CanViewAirlineChart)
    {
    <div class="widget w-col-6" data-widget="airline">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-airplane me-2"></i>Por Airline <small class="text-muted fw-normal">(clique para filtrar)</small><span data-bs-toggle="tooltip" data-bs-placement="top" title="Número de auditorias por companhia aérea." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="airlineChart" height="200"></canvas></div>
        </div>
    </div>
    }
    @if (Model.CanViewAgentChart)
    {
    <div class="widget w-col-6" data-widget="agent">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-person me-2"></i>Por Agente<span data-bs-toggle="tooltip" data-bs-placement="top" title="Número de auditorias por Audit Agent." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="agentChart" height="200"></canvas></div>
        </div>
    </div>
    }

    @if (Model.CanViewComparativeChart)
    {
    <div class="widget w-col-4" data-widget="comparativo">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-calendar me-2"></i>Comparativo anual<span data-bs-toggle="tooltip" data-bs-placement="top" title="Comparação da conformidade entre o ano atual e o anterior." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>@Model.CurrentDataYear</span><strong>@Model.PctYes%</strong>
                </div>
                <div class="progress mb-3" style="height:20px">
                    <div class="progress-bar bg-success" style="width:@Model.PctYes%"></div>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>@Model.CompareYear</span><strong>@Model.PrevPctYes%</strong>
                </div>
                <div class="progress mb-3" style="height:20px">
                    <div class="progress-bar bg-secondary" style="width:@Model.PrevPctYes%"></div>
                </div>
                <div class="text-center mt-2">
                    @{ var diff = Model.DiffPctYes; }
                    <span class="badge @(diff >= 0 ? "bg-success" : "bg-danger") fs-6">
                        <i class="bi bi-arrow-@(diff >= 0 ? "up" : "down")"></i> @Math.Abs(diff)% vs @Model.CompareYear
                    </span>
                </div>
            </div>
        </div>
    </div>
    }
    @if (Model.CanViewOfficerChart)
    {
    <div class="widget w-col-8" data-widget="officer">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-person-badge me-2"></i>Conformidade por Officer <small class="text-muted fw-normal">(clique para detalhe)</small><span data-bs-toggle="tooltip" data-bs-placement="top" title="Taxa de conformidade por AHM Officer. Verde ≥95%, amarelo 80-94%, vermelho <80%." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="officerChart" height="120"></canvas></div>
        </div>
    </div>
    }

    @if (Model.CanViewQuarterProgress)
    {
    <div class="widget w-col-12" data-widget="quarterprogress">
        <div class="card">
            <div class="card-header fw-bold"><i class="bi bi-calendar3 me-2"></i>Progresso trimestral @Model.CurrentYear<span data-bs-toggle="tooltip" data-bs-placement="top" title="Auditorias por trimestre do ano atual." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var q in Model.QuarterProgress)
                    {
                        var isCurrentQ = q.Label.Contains($"Q{Model.CurrentQuarter}");
                        <div class="col-md-3">
                            <div class="p-3 rounded @(isCurrentQ ? "border border-primary" : "bg-light")">
                                <div class="fw-bold @(isCurrentQ ? "text-primary" : "")">@q.Label @(isCurrentQ ? "← atual" : "")</div>
                                <div style="font-size:2rem;font-weight:900">@q.Count</div>
                                <div class="text-muted small">auditorias</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    }

</div><!-- end dashboardGrid -->

<!-- Officer drill-down modal: razões de NO + link para auditorias -->
<div class="modal fade" id="officerDrillModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-badge me-2"></i>Razões de NOT OK — <span id="drillOfficerName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-3 border-bottom">
                    <a id="drillOfficerAllLink" href="#" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-list-check me-1"></i>Ver todas as auditorias deste officer
                    </a>
                </div>
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr><th>Razão</th><th class="text-center">Ocorrências</th><th class="text-end">Ver auditorias</th></tr>
                    </thead>
                    <tbody id="drillOfficerBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
.kpi-card { border: none; border-radius: 12px; transition: transform .2s; }
.kpi-card:hover { transform: translateY(-2px); }
.kpi-label { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
.kpi-value { font-size: 2.2rem; font-weight: 900; line-height: 1.1; color: #1e293b; }
.kpi-trend { font-size: 12px; margin-top: 4px; }
.kpi-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
.bg-primary-soft { background: #dbeafe; }
.bg-success-soft { background: #dcfce7; }
.bg-danger-soft  { background: #fee2e2; }

/* Dashboard grid — cada card é um widget independente; grid-auto-flow: dense fecha
   automaticamente os espaços quando algum widget fica escondido por permissões. */
#dashboardGrid { display: grid; grid-template-columns: repeat(12, 1fr); grid-auto-flow: dense; gap: 1rem; margin-bottom: 1.5rem; }
#dashboardGrid .widget { min-width: 0; }
.w-col-4  { grid-column: span 4; }
.w-col-5  { grid-column: span 5; }
.w-col-6  { grid-column: span 6; }
.w-col-7  { grid-column: span 7; }
.w-col-8  { grid-column: span 8; }
.w-col-12 { grid-column: span 12; }
@@media (max-width: 991px) {
    #dashboardGrid .widget { grid-column: 1 / -1 !important; }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Bootstrap tooltips
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
});
</script>
<script>
// Chart color helpers — read the global dark-mode class toggled from the shared layout
const isDark = () => document.body.classList.contains('dark-mode');
const gridColor = () => isDark() ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
const textColor = () => isDark() ? '#e2e8f0' : '#1e293b';

// Trend chart
@if (Model.CanViewTrend)
{
<text>
const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Label).ToList()));
const trendData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Pct).ToList()));
const trendCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Count).ToList()));

new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
        labels: trendLabels,
        datasets: [{
            label: 'Conformidade %',
            data: trendData,
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59,130,246,0.1)',
            tension: 0.4,
            fill: true,
            pointRadius: 4,
            pointHoverRadius: 7
        }]
    },
    options: {
        scales: {
            y: { min: 0, max: 100, grid: { color: gridColor() }, ticks: { color: textColor(), callback: v => v + '%' } },
            x: { grid: { display: false }, ticks: { color: textColor() } }
        },
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { afterLabel: (ctx) => `Auditorias: ${trendCounts[ctx.dataIndex]}` } }
        }
    }
});
</text>
}

// Global conformity doughnut
@if (Model.CanViewGlobalConformity)
{
<text>
const officerStats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerStats));
let resultChart = new Chart(document.getElementById('resultChart'), {
    type: 'doughnut',
    data: { labels:['OK','NOT OK'], datasets:[{ data:[@Model.TotalYes,@Model.TotalNo], backgroundColor:['#22c55e','#ef4444'], borderWidth:2, borderColor:'#fff' }] },
    options: {
        plugins: {
            legend: { position: 'bottom' },
            tooltip: {
                callbacks: {
                    label: (ctx) => {
                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                        const pct = total > 0 ? Math.round(ctx.parsed * 100 / total) : 0;
                        return `${ctx.label}: ${ctx.parsed} (${pct}%)`;
                    }
                }
            }
        },
        cutout: '70%',
        onClick: (e, elements) => {
            if (elements.length > 0) {
                window.location.href = elements[0].index === 0 ? '/Auditorias?compliance=ok' : '/Auditorias?compliance=notok';
            }
        }
    }
});
document.getElementById('resultChart').style.cursor = 'pointer';
</text>
}

// Razões de NOT OK — substitui o antigo gráfico de Top NCs
@if (Model.CanViewNonConformities)
{
<text>
const reasonLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReasonStats.Select(x => x.Reason).ToList()));
const reasonData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReasonStats.Select(x => x.Count).ToList()));
new Chart(document.getElementById('reasonChart'), {
    type: 'bar',
    data: { labels: reasonLabels, datasets: [{ label: 'Ocorrências', data: reasonData, backgroundColor: '#ef4444', borderRadius: 6 }] },
    options: {
        indexAxis: 'y',
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: gridColor() }, ticks: { color: textColor() } },
            y: { grid: { display: false }, ticks: { color: textColor(), font: { size: 11 } } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) {
                const reason = encodeURIComponent(reasonLabels[elements[0].index]);
                window.location.href = `/Auditorias?ncReason=${reason}`;
            }
        }
    }
});
if (reasonLabels.length > 0) document.getElementById('reasonChart').style.cursor = 'pointer';
</text>
}

// Section chart
@if (Model.CanViewSectionChart)
{
<text>
const secLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SectionData.Select(s => s.name).ToList()));
const secData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SectionData.Select(s => s.pct).ToList()));
const secColors = secData.map(v => v >= 95 ? '#22c55e' : v >= 80 ? '#f59e0b' : '#ef4444');
new Chart(document.getElementById('sectionChart'), {
    type: 'bar',
    data: { labels: secLabels, datasets: [{ label: 'Conformidade %', data: secData, backgroundColor: secColors, borderRadius: 6 }] },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { min: 0, max: 100, ticks: { color: textColor(), callback: v => v + '%' }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor(), font: { size: 11 }, autoSkip: true, maxRotation: 30, minRotation: 0 }, grid: { display: false } }
        }
    }
});
</text>
}

// Airline chart
@if (Model.CanViewAirlineChart)
{
<text>
const airlineLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AirlineLabels));
const airlineValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AirlineValues));
const airlineChart = new Chart(document.getElementById('airlineChart'), {
    type: 'bar',
    data: { labels: airlineLabels, datasets: [{ label: 'Auditorias', data: airlineValues, backgroundColor: '#3b82f6', borderRadius: 6 }] },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { ticks: { color: textColor() }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor(), autoSkip: true, maxRotation: 45, minRotation: 0 }, grid: { display: false } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) {
                const airline = encodeURIComponent(airlineLabels[elements[0].index]);
                window.location.href = `/Auditorias?airline=${airline}`;
            }
        }
    }
});
document.getElementById('airlineChart').style.cursor = 'pointer';
</text>
}

// Officer drill-down: razões de NO reais desse officer, cada uma com link para as auditorias
// (função e dados independentes de qualquer canvas — seguro definir sempre)
const officerReasonDrill = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.OfficerReasonDrill.ToDictionary(kv => kv.Key, kv => kv.Value)
));

function showOfficerDrill(officerName) {
    document.getElementById('drillOfficerName').textContent = officerName;
    document.getElementById('drillOfficerAllLink').href = `/Auditorias?officer=${encodeURIComponent(officerName)}`;
    const data = officerReasonDrill[officerName] || [];
    const tbody = document.getElementById('drillOfficerBody');
    if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">Sem não conformidades registadas</td></tr>';
    } else {
        tbody.innerHTML = data.map(d => `
            <tr>
                <td><small>${d.Reason}</small></td>
                <td class="text-center text-danger fw-bold">${d.Count}</td>
                <td class="text-end">
                    <a href="/Auditorias?officer=${encodeURIComponent(officerName)}&ncReason=${encodeURIComponent(d.Reason)}" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-eye"></i> Ver
                    </a>
                </td>
            </tr>`).join('');
    }
    new bootstrap.Modal(document.getElementById('officerDrillModal')).show();
}

