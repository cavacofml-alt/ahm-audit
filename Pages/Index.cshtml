@if (Model.CanViewOfficerChart)
{
<text>
// Officer conformity chart
const officerChartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerLabels));
const officerChartData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerConformity));
const officerColors      = officerChartData.map(v => v >= 95 ? '#22c55e' : v >= 80 ? '#f59e0b' : '#ef4444');
new Chart(document.getElementById('officerChart'), {
    type: 'bar',
    data: { labels: officerChartLabels, datasets: [{ label: 'Conformidade %', data: officerChartData, backgroundColor: officerColors, borderRadius: 6 }] },
    options: {
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { footer: () => 'Clique para ver falhas detalhadas' } }
        },
        scales: {
            y: { min: 0, max: 100, ticks: { color: textColor(), callback: v => v + '%' }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor(), autoSkip: true, maxRotation: 45, minRotation: 0 }, grid: { display: false } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) showOfficerDrill(officerChartLabels[elements[0].index]);
        }
    }
});
document.getElementById('officerChart').style.cursor = 'pointer';
</text>
}
</script>
