@page
@model AHM.Audit.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var pctInt = int.Parse(Model.PctYes);
    var scoreColor = pctInt >= 95 ? "#22c55e" : pctInt >= 85 ? "#f59e0b" : "#ef4444";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-sm btn-outline-secondary" id="darkToggle" title="Toggle dark mode">
            <i class="bi bi-moon-fill" id="darkIcon"></i>
        </button>
    </div>
</div>

<!-- Filters -->
<form method="get" class="card mb-4 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small fw-bold">De</label>
            <input type="date" name="from" class="form-control form-control-sm" value="@(Model.FilterFrom?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Até</label>
            <input type="date" name="to" class="form-control form-control-sm" value="@(Model.FilterTo?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Airline</label>
            <select name="airline" class="form-select form-select-sm">
                <option value="">Todas</option>
                @foreach (var a in Model.AllAirlines)
                { <option value="@a" selected="@(Model.FilterAirline == a)">@a</option> }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Agente</label>
            <select name="agent" class="form-select form-select-sm">
                <option value="">Todos</option>
                @foreach (var a in Model.AllAgents)
                { <option value="@a" selected="@(Model.FilterAgent == a)">@a</option> }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">Filtrar</button>
        </div>
        <div class="col-md-2">
            <a href="/" class="btn btn-outline-secondary btn-sm w-100">Limpar</a>
        </div>
    </div>
</form>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    @{
        var tmDiffTotal = Model.ThisMonthTotal - Model.LastMonthTotal;
        var tmDiffPct   = Model.ThisMonthPct - Model.LastMonthPct;
        var tmDiffNC    = Model.ThisMonthNC - Model.LastMonthNC;
    }
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Auditorias este mês</div>
                        <div class="kpi-value">@Model.ThisMonthTotal</div>
                        <div class="kpi-trend @(tmDiffTotal >= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffTotal >= 0 ? "up" : "down")"></i>
                            @(Math.Abs(tmDiffTotal)) vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-primary-soft"><i class="bi bi-clipboard-check text-primary"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Conformidade este mês</div>
                        <div class="kpi-value">@Model.ThisMonthPct<span style="font-size:1rem">%</span></div>
                        <div class="kpi-trend @(tmDiffPct >= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffPct >= 0 ? "up" : "down")"></i>
                            @(Math.Abs(tmDiffPct))% vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-success-soft"><i class="bi bi-check-circle text-success"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="kpi-label">Não conformidades</div>
                        <div class="kpi-value">@Model.ThisMonthNC</div>
                        <div class="kpi-trend @(tmDiffNC <= 0 ? "text-success" : "text-danger")">
                            <i class="bi bi-arrow-@(tmDiffNC <= 0 ? "down" : "up")"></i>
                            @(Math.Abs(tmDiffNC)) vs mês anterior
                        </div>
                    </div>
                    <div class="kpi-icon bg-danger-soft"><i class="bi bi-exclamation-triangle text-danger"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card h-100" style="border-left: 4px solid @scoreColor">
            <div class="card-body text-center">
                <div class="kpi-label">Overall Quality Score</div>
                <div style="font-size:3rem;font-weight:900;color:@scoreColor;line-height:1">@Model.PctYes%</div>
                <div style="font-size:1.5rem;font-weight:700;color:@scoreColor">@Model.ScoreGrade</div>
                <div class="kpi-trend">Última: @Model.LastAuditTime</div>
            </div>
        </div>
    </div>
</div>

<!-- Trend + Global Conformity -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-graph-up me-2"></i>Tendência 12 meses<span data-bs-toggle="tooltip" data-bs-placement="top" title="Evolução mensal da conformidade (YES/Total) nos últimos 12 meses. Permite identificar tendências de melhoria ou degradação." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="trendChart" height="120"></canvas></div>
        </div>
    </div>
    @if (Model.CanViewGlobalConformity)
    {
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-pie-chart me-2"></i>Conformidade global<span data-bs-toggle="tooltip" data-bs-placement="top" title="Rácio global entre itens OK e NOT OK em todas as auditorias do período selecionado. N/A não é contabilizado." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <canvas id="resultChart" width="200" height="200"></canvas>
                <div class="mt-2 text-center">
                    <span class="badge bg-success me-2">OK @Model.TotalYes</span>
                    <span class="badge bg-danger">NOT OK @Model.TotalNo</span>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<!-- Heatmap + Top NCs -->
<div class="row g-3 mb-4">
    @if (Model.CanViewSectionChart)
    {
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-grid-3x3 me-2"></i>Checklist — detalhe por campo<span data-bs-toggle="tooltip" data-bs-placement="top" title="Mostra o resultado de cada item da checklist. Verde=OK, Vermelho=NOT OK, Cinza=N/A. Agrupado por secção." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body p-0" style="max-height:500px;overflow-y:auto">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th style="width:45%">Campo</th>
                            <th class="text-center text-success">YES</th>
                            <th class="text-center text-danger">NO</th>
                            <th class="text-center text-secondary">N/A</th>
                            <th class="text-end">Conf.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.SectionData.OrderBy(x => x.key))
                        {
                            <tr class="table-secondary">
                                <td colspan="5"><strong>@s.name</strong></td>
                            </tr>
                            @foreach (var item in Model.ChecklistDetail.Where(x => x.SectionKey == s.key))
                            {
                                var conf = (item.Yes + item.No) > 0 ? item.Yes * 100 / (item.Yes + item.No) : -1;
                                var rowBg = conf == -1 ? "" : conf >= 95 ? "rgba(34,197,94,0.08)" : conf >= 80 ? "rgba(245,158,11,0.12)" : "rgba(239,68,68,0.08)";
                                var confColor = conf == -1 ? "text-muted" : conf >= 95 ? "text-success" : conf >= 80 ? "text-warning" : "text-danger";
                                <tr style="background:@rowBg">
                                    <td><small>@item.Label</small></td>
                                    <td class="text-center text-success fw-bold">@item.Yes</td>
                                    <td class="text-center text-danger fw-bold">
                                        @if (item.No > 0)
                                        {
                                            <a href="/Auditorias?ncFilter=@Uri.EscapeDataString(item.Label)" class="text-danger fw-bold text-decoration-none" title="Ver auditorias com NOT OK neste campo">@item.No</a>
                                        }
                                        else { <span>0</span> }
                                    </td>
                                    <td class="text-center text-secondary">@item.Na</td>
                                    <td class="text-end fw-bold @confColor">@(conf >= 0 ? conf + "%" : "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    }
    @if (Model.CanViewNonConformities)
    {
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-bar-chart-horizontal me-2"></i>Top não conformidades <small class="text-muted fw-normal">(clique para filtrar)</small><span data-bs-toggle="tooltip" data-bs-placement="top" title="Os 10 itens da checklist com maior número de ocorrências NOT OK. Ordenado por frequência absoluta." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="ncChart" height="200"></canvas></div>
        </div>
    </div>
    }
</div>

<!-- Pareto + Section bar -->
<div class="row g-3 mb-4">
    </div>

<!-- Progresso trimestral -->
<div class="row g-3 mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header fw-bold"><i class="bi bi-calendar3 me-2"></i>Progresso trimestral @Model.CurrentYear<span data-bs-toggle="tooltip" data-bs-placement="top" title="Número de auditorias realizadas em cada trimestre do ano atual. O trimestre corrente está destacado." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var q in Model.QuarterProgress)
                    {
                        var isCurrentQ = q.Label.Contains($"Q{Model.CurrentQuarter}");
                        <div class="col-md-3">
                            <div class="p-3 rounded @(isCurrentQ ? "border border-primary" : "bg-light")">
                                <div class="fw-bold @(isCurrentQ ? "text-primary" : "")">@q.Label @(isCurrentQ ? "← atual" : "")</div>
                                <div style="font-size:2rem;font-weight:900">@q.Count</div>
                                <div class="text-muted small">auditorias</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Por airline + Por agente -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-airplane me-2"></i>Por Airline <small class="text-muted fw-normal">(clique para filtrar)</small><span data-bs-toggle="tooltip" data-bs-placement="top" title="Número de auditorias realizadas por companhia aérea no período selecionado." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="airlineChart" height="200"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-person me-2"></i>Por Agente<span data-bs-toggle="tooltip" data-bs-placement="top" title="Número de auditorias realizadas por cada Audit Agent no período selecionado." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="agentChart" height="200"></canvas></div>
        </div>
    </div>
</div>

<!-- Comparativo ano anterior -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-bold"><i class="bi bi-calendar me-2"></i>Comparativo anual<span data-bs-toggle="tooltip" data-bs-placement="top" title="Comparação da conformidade global entre o ano atual e o ano anterior." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>@Model.CurrentDataYear</span>
                    <strong>@Model.PctYes%</strong>
                </div>
                <div class="progress mb-3" style="height:20px">
                    <div class="progress-bar bg-success" style="width:@Model.PctYes%"></div>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>@Model.CompareYear</span>
                    <strong>@Model.PrevPctYes%</strong>
                </div>
                <div class="progress mb-3" style="height:20px">
                    <div class="progress-bar bg-secondary" style="width:@Model.PrevPctYes%"></div>
                </div>
                <div class="text-center mt-2">
                    @{ var diff = Model.DiffPctYes; }
                    <span class="badge @(diff >= 0 ? "bg-success" : "bg-danger") fs-6">
                        <i class="bi bi-arrow-@(diff >= 0 ? "up" : "down")"></i> @Math.Abs(diff)% vs @Model.CompareYear
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-person-badge me-2"></i>Conformidade por Officer<span data-bs-toggle="tooltip" data-bs-placement="top" title="Taxa de conformidade das auditorias supervisionadas por cada AHM Officer. Verde ≥95%, amarelo 80-94%, vermelho <80%." style="cursor:help; margin-left:6px; font-size:13px; color:#94a3b8"><i class="bi bi-info-circle"></i></span></div>
            <div class="card-body"><canvas id="officerChart" height="120"></canvas></div>
        </div>
    </div>
</div>

<!-- Agent drill-down modal -->
<div class="modal fade" id="agentDrillModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-badge me-2"></i>Falhas de <span id="drillAgentName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr><th>Campo</th><th class="text-center">NOT OK</th><th class="text-end">% de falha</th></tr>
                    </thead>
                    <tbody id="drillAgentBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
.kpi-card { border: none; border-radius: 12px; transition: transform .2s; }
.kpi-card:hover { transform: translateY(-2px); }
.kpi-label { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
.kpi-value { font-size: 2.2rem; font-weight: 900; line-height: 1.1; color: #1e293b; }
.kpi-trend { font-size: 12px; margin-top: 4px; }
.kpi-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
.bg-primary-soft { background: #dbeafe; }
.bg-success-soft { background: #dcfce7; }
.bg-danger-soft  { background: #fee2e2; }

/* Dark mode */
body.dark-mode { background: #0f172a !important; color: #e2e8f0 !important; }
body.dark-mode .card { background: #1e293b !important; border-color: #334155 !important; color: #e2e8f0 !important; }
body.dark-mode .card-header { background: #1e293b !important; border-color: #334155 !important; color: #e2e8f0 !important; }
body.dark-mode .kpi-value { color: #f1f5f9 !important; }
body.dark-mode .kpi-label { color: #94a3b8 !important; }
body.dark-mode .table { color: #e2e8f0 !important; }
body.dark-mode .table-hover tbody tr:hover { background: #334155 !important; }
body.dark-mode .form-control, body.dark-mode .form-select { background: #1e293b !important; color: #e2e8f0 !important; border-color: #334155 !important; }
body.dark-mode .sidebar { background: #0f172a !important; }
body.dark-mode .progress { background: #334155 !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Bootstrap tooltips
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
});
</script>
<script>
// Dark mode
const darkToggle = document.getElementById('darkToggle');
const darkIcon   = document.getElementById('darkIcon');
const savedTheme = localStorage.getItem('theme');
if (savedTheme === 'dark') { document.body.classList.add('dark-mode'); darkIcon.className = 'bi bi-sun-fill'; }

darkToggle.addEventListener('click', () => {
    document.body.classList.toggle('dark-mode');
    const isDark = document.body.classList.contains('dark-mode');
    darkIcon.className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
});

const isDark = () => document.body.classList.contains('dark-mode');
const gridColor = () => isDark() ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
const textColor = () => isDark() ? '#e2e8f0' : '#1e293b';

// Trend chart
const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Label).ToList()));
const trendData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Pct).ToList()));
const trendCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(m => m.Count).ToList()));

new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
        labels: trendLabels,
        datasets: [{
            label: 'Conformidade %',
            data: trendData,
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59,130,246,0.1)',
            tension: 0.4,
            fill: true,
            pointRadius: 4,
            pointHoverRadius: 7
        }]
    },
    options: {
        scales: {
            y: { min: 0, max: 100, grid: { color: gridColor() }, ticks: { color: textColor(), callback: v => v + '%' } },
            x: { grid: { display: false }, ticks: { color: textColor() } }
        },
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { afterLabel: (ctx) => `Auditorias: ${trendCounts[ctx.dataIndex]}` } }
        }
    }
});

// Global conformity doughnut
@if (Model.CanViewGlobalConformity)
{
<text>
const officerStats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerStats));
let resultChart = new Chart(document.getElementById('resultChart'), {
    type: 'doughnut',
    data: { labels:['OK','NOT OK'], datasets:[{ data:[@Model.TotalYes,@Model.TotalNo], backgroundColor:['#22c55e','#ef4444'], borderWidth:2, borderColor:'#fff' }] },
    options: { plugins: { legend: { position: 'bottom' } }, cutout: '70%' }
});
</text>
}

// Top NCs horizontal bar
@if (Model.CanViewNonConformities)
{
<text>
const ncLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopNonConformities.Select(x => x.label).ToList()));
const ncData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopNonConformities.Select(x => x.count).ToList()));
const ncFieldNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopNonConformities.Select(x => x.label).ToList()));
const ncChart = new Chart(document.getElementById('ncChart'), {
    type: 'bar',
    data: { labels: ncLabels, datasets: [{ label: 'Ocorrências', data: ncData, backgroundColor: '#ef4444', borderRadius: 6 }] },
    options: {
        indexAxis: 'y',
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: gridColor() }, ticks: { color: textColor() } },
            y: { grid: { display: false }, ticks: { color: textColor(), font: { size: 11 } } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) {
                const label = encodeURIComponent(ncLabels[elements[0].index]);
                window.location.href = `/Auditorias?ncFilter=${label}`;
            }
        }
    }
});
document.getElementById('ncChart').style.cursor = 'pointer';


</text>
}

// Section chart
@if (Model.CanViewSectionChart)
{
<text>
const secLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SectionData.Select(s => s.name).ToList()));
const secData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SectionData.Select(s => s.pct).ToList()));
const secColors = secData.map(v => v >= 95 ? '#22c55e' : v >= 80 ? '#f59e0b' : '#ef4444');
new Chart(document.getElementById('sectionChart'), {
    type: 'bar',
    data: { labels: secLabels, datasets: [{ label: 'Conformidade %', data: secData, backgroundColor: secColors, borderRadius: 6 }] },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { min: 0, max: 100, ticks: { color: textColor(), callback: v => v + '%' }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor(), font: { size: 11 } }, grid: { display: false } }
        }
    }
});
</text>
}

// Airline chart
const airlineLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AirlineLabels));
const airlineValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AirlineValues));
const airlineChart = new Chart(document.getElementById('airlineChart'), {
    type: 'bar',
    data: { labels: airlineLabels, datasets: [{ label: 'Auditorias', data: airlineValues, backgroundColor: '#3b82f6', borderRadius: 6 }] },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { ticks: { color: textColor() }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor() }, grid: { display: false } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) {
                const airline = encodeURIComponent(airlineLabels[elements[0].index]);
                window.location.href = `/Auditorias?airline=${airline}`;
            }
        }
    }
});
document.getElementById('airlineChart').style.cursor = 'pointer';

// Agent chart
// Agent drill-down data
const agentDrillData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.OfficerStats.ToDictionary(
        kv => kv.Key,
        kv => Model.ChecklistDetail
            .Where(x => x.No > 0)
            .Select(x => new { label = x.Label, no = x.No, pct = (x.Yes + x.No) > 0 ? x.No * 100 / (x.Yes + x.No) : 0 })
            .OrderByDescending(x => x.no)
            .Take(10)
            .ToList()
    )
));

function showAgentDrill(agentName) {
    document.getElementById('drillAgentName').textContent = agentName;
    const data = agentDrillData[agentName] || [];
    const tbody = document.getElementById('drillAgentBody');
    if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">Sem não conformidades registadas</td></tr>';
    } else {
        tbody.innerHTML = data.map(d => `
            <tr>
                <td><small>${d.label}</small></td>
                <td class="text-center text-danger fw-bold">${d.no}</td>
                <td class="text-end text-danger">${d.pct}%</td>
            </tr>`).join('');
    }
    new bootstrap.Modal(document.getElementById('agentDrillModal')).show();
}

const agentLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AgentLabels));
const agentValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AgentValues));
new Chart(document.getElementById('agentChart'), {
    type: 'bar',
    data: { labels: agentLabels, datasets: [{ label: 'Auditorias', data: agentValues, backgroundColor: '#8b5cf6', borderRadius: 6 }] },
    options: {
        plugins: { legend: { display: false } },
        scales: {
            y: { ticks: { color: textColor() }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor() }, grid: { display: false } }
        }
    }
});

// Officer conformity chart
const officerChartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerLabels));
const officerChartData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OfficerConformity));
const officerColors      = officerChartData.map(v => v >= 95 ? '#22c55e' : v >= 80 ? '#f59e0b' : '#ef4444');
new Chart(document.getElementById('officerChart'), {
    type: 'bar',
    data: { labels: officerChartLabels, datasets: [{ label: 'Conformidade %', data: officerChartData, backgroundColor: officerColors, borderRadius: 6 }] },
    options: {
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { footer: () => 'Clique para ver falhas detalhadas' } }
        },
        scales: {
            y: { min: 0, max: 100, ticks: { color: textColor(), callback: v => v + '%' }, grid: { color: gridColor() } },
            x: { ticks: { color: textColor() }, grid: { display: false } }
        },
        onClick: (e, elements) => {
            if (elements.length > 0) showAgentDrill(officerChartLabels[elements[0].index]);
        }
    }
});
document.getElementById('officerChart').style.cursor = 'pointer';
document.getElementById('agentChart') && (document.getElementById('agentChart').style.cursor = 'pointer');
</script>
