@page
@{
    ViewData["Title"] = "Erro";
}
<div class="d-flex align-items-center justify-content-center" style="min-height:60vh">
    <div class="text-center">
        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:4rem"></i>
        <h2 class="mt-3">Ocorreu um erro inesperado</h2>
        <p class="text-muted">Por favor tenta novamente. Se o problema persistir, contacta o administrador.</p>
        <a href="/" class="btn btn-primary mt-2"><i class="bi bi-house me-2"></i>Voltar ao início</a>
    </div>
</div>
