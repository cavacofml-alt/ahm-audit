@page
@model AHM.Audit.Pages.Admin.BackupModel
@{
    ViewData["Title"] = "Backup & Restauro";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-database me-2"></i>Backup & Restauro</h2>
    <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible">
        @Model.Message
    </div>
}

<div class="row g-4">
    <!-- Exportar -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-download me-2"></i>Exportar Backup</div>
            <div class="card-body">
                <p class="text-muted small">Descarrega todas as auditorias em CSV.</p>
                <a href="/Admin/BackupExport" class="btn btn-success w-100">
                    <i class="bi bi-file-earmark-arrow-down me-2"></i>Descarregar Backup CSV
                </a>
            </div>
        </div>
    </div>

    <!-- Importar -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-bold"><i class="bi bi-upload me-2"></i>Restaurar Backup</div>
            <div class="card-body">
                <p class="text-muted small">Faz upload de um ficheiro CSV para restaurar as auditorias. Tickets duplicados serão ignorados.</p>
                <form action="/Admin/Backup?handler=Import" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" class="form-control" name="csvFile" accept=".csv" />
                    </div>
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="bi bi-file-earmark-arrow-up me-2"></i>Importar CSV
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Apagar tudo -->
    <div class="col-md-4">
        <div class="card h-100 border-danger">
            <div class="card-header fw-bold text-danger"><i class="bi bi-trash me-2"></i>Apagar Todas as Auditorias</div>
            <div class="card-body">
                <p class="text-muted small">Apaga permanentemente todas as auditorias. Esta ação não pode ser desfeita.</p>
                <div class="alert alert-danger small py-2">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>Faz um backup antes de continuar!
                </div>
                <button type="button" class="btn btn-danger w-100" onclick="confirmDelete()">
                    <i class="bi bi-trash me-2"></i>Apagar Tudo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal confirmação -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmação</h5>
            </div>
            <div class="modal-body">
                <p>Tens a certeza que queres apagar <strong>todas as auditorias</strong>?</p>
                <p class="text-danger fw-bold">Esta ação é irreversível.</p>
                <label class="form-label">Escreve <strong>APAGAR</strong> para confirmar:</label>
                <input type="text" id="confirmText" class="form-control" placeholder="APAGAR" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form action="/Admin/Backup?handler=DeleteAll" method="post" id="deleteForm">
                    <button type="submit" class="btn btn-danger" id="confirmBtn" disabled>Apagar Tudo</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function confirmDelete() {
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
document.getElementById('confirmText').addEventListener('input', function() {
    document.getElementById('confirmBtn').disabled = this.value !== 'APAGAR';
});
</script>
