@page
@model AHM.Audit.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Gestão de Utilizadores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-people me-2"></i>Gestão de Utilizadores</h2>
    <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<!-- Criar novo utilizador -->
<div class="card mb-4">
    <div class="card-header fw-bold">Criar Novo Utilizador</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Create">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Username</label>
                    <input class="form-control" name="newUsername" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Password</label>
                    <input class="form-control" type="password" name="newPassword" required />
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" name="isAdmin" value="true" id="isAdminCheck" />
                        <label class="form-check-label" for="isAdminCheck">Admin</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100">Criar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Lista de utilizadores -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Perfil</th>
                    <th>Estado</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td>@u.Username</td>
                        <td><span class="badge @(u.IsAdmin ? "bg-danger" : "bg-secondary")">@(u.IsAdmin ? "Admin" : "Utilizador")</span></td>
                        <td><span class="badge @(u.Active ? "bg-success" : "bg-secondary")">@(u.Active ? "Ativo" : "Inativo")</span></td>
                        <td class="d-flex gap-2 flex-wrap">
                            <!-- Editar username -->
                            <form method="post" asp-page-handler="EditUsername" class="d-inline d-flex gap-1">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <input type="text" name="newUsername" value="@u.Username" class="form-control form-control-sm" style="width:140px" required />
                                <button class="btn btn-sm btn-outline-primary">Guardar</button>
                            </form>
                            <!-- Reset password -->
                            <form method="post" asp-page-handler="ResetPassword" class="d-inline d-flex gap-1">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <input type="text" name="newPass" placeholder="Nova password" class="form-control form-control-sm" style="width:140px" required />
                                <button class="btn btn-sm btn-warning">Reset PW</button>
                            </form>
                            <!-- Ativar/Desativar -->
                            <form method="post" asp-page-handler="ToggleActive" class="d-inline">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button class="btn btn-sm @(u.Active ? "btn-outline-danger" : "btn-outline-success")">
                                    @(u.Active ? "Desativar" : "Ativar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
