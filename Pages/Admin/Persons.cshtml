@page
@model AHM.Audit.Pages.Admin.PersonsModel
@{
    ViewData["Title"] = "Agentes e Officers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-person-badge me-2"></i>Agentes e AHM Officers</h2>
    <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<div class="row g-4">
    <!-- Agents -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">Audit Agents</div>
            <div class="card-body">
                <form action="/Admin/Persons?handler=Add" method="post" class="d-flex gap-2 mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="role" value="Agent" />
                    <input class="form-control" name="name" placeholder="Nome do agente" required />
                    <button class="btn btn-primary">Adicionar</button>
                </form>
                <ul class="list-group">
                    @foreach (var p in Model.Agents)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span id="name-@p.Id" class="person-name">@p.Name</span>
                            <input type="text" id="edit-@p.Id" class="form-control form-control-sm d-none" value="@p.Name" style="max-width:180px" />
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary" onclick="startEdit(@p.Id)" id="editBtn-@p.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form action="/Admin/Persons?handler=EditName" method="post" id="editForm-@p.Id" class="d-none">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <input type="hidden" name="newName" id="editHidden-@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check"></i></button>
                                </form>
                                <button class="btn btn-sm btn-outline-secondary d-none" id="cancelBtn-@p.Id" onclick="cancelEdit(@p.Id)">
                                    <i class="bi bi-x"></i>
                                </button>
                                <form action="/Admin/Persons?handler=Toggle" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <button class="btn btn-sm @(p.Active ? "btn-outline-danger" : "btn-outline-success")">
                                        @(p.Active ? "Desativar" : "Ativar")
                                    </button>
                                </form>
                                <form action="/Admin/Persons?handler=Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Apagar \'@p.Name\' de vez? Esta acao nao pode ser desfeita (as auditorias ja existentes mantem o nome, mas deixa de aparecer para novas auditorias).');">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <button class="btn btn-sm btn-danger" title="Apagar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Officers -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">AHM Officers</div>
            <div class="card-body">
                <form action="/Admin/Persons?handler=Add" method="post" class="d-flex gap-2 mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="role" value="Officer" />
                    <input class="form-control" name="name" placeholder="Nome do officer" required />
                    <button class="btn btn-primary">Adicionar</button>
                </form>
                <ul class="list-group">
                    @foreach (var p in Model.Officers)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span id="name-@p.Id" class="person-name">@p.Name</span>
                            <input type="text" id="edit-@p.Id" class="form-control form-control-sm d-none" value="@p.Name" style="max-width:180px" />
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary" onclick="startEdit(@p.Id)" id="editBtn-@p.Id">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form action="/Admin/Persons?handler=EditName" method="post" id="editForm-@p.Id" class="d-none">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <input type="hidden" name="newName" id="editHidden-@p.Id" />
                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check"></i></button>
                                </form>
                                <button class="btn btn-sm btn-outline-secondary d-none" id="cancelBtn-@p.Id" onclick="cancelEdit(@p.Id)">
                                    <i class="bi bi-x"></i>
                                </button>
                                <form action="/Admin/Persons?handler=Toggle" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <button class="btn btn-sm @(p.Active ? "btn-outline-danger" : "btn-outline-success")">
                                        @(p.Active ? "Desativar" : "Ativar")
                                    </button>
                                </form>
                                <form action="/Admin/Persons?handler=Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Apagar \'@p.Name\' de vez? Esta acao nao pode ser desfeita (as auditorias ja existentes mantem o nome, mas deixa de aparecer para novas auditorias).');">
                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="personId" value="@p.Id" />
                                    <button class="btn btn-sm btn-danger" title="Apagar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
function startEdit(id) {
    document.getElementById('name-' + id).classList.add('d-none');
    document.getElementById('edit-' + id).classList.remove('d-none');
    document.getElementById('editBtn-' + id).classList.add('d-none');
    document.getElementById('editForm-' + id).classList.remove('d-none');
    document.getElementById('cancelBtn-' + id).classList.remove('d-none');
    document.getElementById('edit-' + id).focus();
}

function cancelEdit(id) {
    document.getElementById('name-' + id).classList.remove('d-none');
    document.getElementById('edit-' + id).classList.add('d-none');
    document.getElementById('editBtn-' + id).classList.remove('d-none');
    document.getElementById('editForm-' + id).classList.add('d-none');
    document.getElementById('cancelBtn-' + id).classList.add('d-none');
}

document.querySelectorAll('[id^="editForm-"]').forEach(form => {
    form.addEventListener('submit', function(e) {
        const id = this.id.replace('editForm-', '');
        document.getElementById('editHidden-' + id).value = document.getElementById('edit-' + id).value;
    });
});
</script>
